<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gmp.workflow.mapper.CommentInfoMapper">

    <select id="getCommentInfosByProcessInstanceId" resultType="com.gmp.workflow.model.flowable.CommentInfo">
        SELECT * FROM tbl_flow_comment_info
        WHERE process_instance_id = #{processInstanceId}
        ORDER BY time ASC
    </select>

</mapper>
