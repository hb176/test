<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gmp.workflow.mapper.ModelInfoMapper">

    <select id="getPagerModel" resultType="com.gmp.workflow.model.flowable.ModelInfo">
        SELECT * FROM tbl_flow_model_info
        <where>
            <if test="modelInfo.appSn != null and modelInfo.appSn != ''">
                AND app_sn = #{modelInfo.appSn}
            </if>
            <if test="modelInfo.name != null and modelInfo.name != ''">
                AND name LIKE CONCAT('%', #{modelInfo.name}, '%')
            </if>
            <if test="modelInfo.modelKey != null and modelInfo.modelKey != ''">
                AND model_key = #{modelInfo.modelKey}
            </if>
            <if test="modelInfo.status != null">
                AND status = #{modelInfo.status}
            </if>
        </where>
        ORDER BY order_no ASC, create_time DESC
    </select>

</mapper>
